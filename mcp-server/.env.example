# GhostMind MCP Server Configuration
# =====================================

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── LLM API Keys (at least one required for question answering) ──────────────
# These are used to answer yes/no questions about characters privately
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ─── Redis Storage (Upstash - recommended for production) ─────────────────────
# Get free tier at: https://upstash.com
# Without these, game data is stored in memory and lost on restart!
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Admin Security (required for production) ─────────────────────────────────
# Protects /admin/* endpoints that expose game secrets
ADMIN_SECRET=your-secret-token-here

# ─── Legacy C-lite Configuration ──────────────────────────────────────────────
# (Only needed if running clite-server.mjs)
PRIVATE_KEY=0x...
CONTRACT_ADDRESS=0x...
RPC_URL=https://api.infra.testnet.somnia.network
MCP_INTERNAL_URL=http://127.0.0.1:3001
SECRETS_FILE=./clite-secrets.json

# Defaults for newly created games (in STT)
DEFAULT_BOND=0.1
DEFAULT_POT=0.1
DEFAULT_GAME_FEE=0.01
